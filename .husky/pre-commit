#!/bin/sh

FRONTEND_STAGED=$(git diff --cached --name-only | grep "^frontend/src/" || true)
BACKEND_STAGED=$(git diff --cached --name-only | grep "^backend/src/" || true)

if [ -n "$FRONTEND_STAGED" ]; then
  echo "→ frontend: prettier + lint on staged files"
  (cd frontend && npx lint-staged) || exit 1
  echo "→ frontend: unit tests"
  (cd frontend && npm run test) || exit 1
fi

if [ -n "$BACKEND_STAGED" ]; then
  echo "→ backend: prettier + lint on staged files"
  (cd backend && npx lint-staged) || exit 1
fi
